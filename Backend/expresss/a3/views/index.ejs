<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Welcome to the Image Gallery</h1>
    <div class="image-gallery">
        <% fotos.forEach(foto => { %>
            <img src="<%= foto %>" alt="Image" style="width: 200px; height: auto; margin: 10px;">
        <% }); %>
    </div>
</body>
</html>